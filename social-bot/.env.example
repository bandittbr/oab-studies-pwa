# ── Instagram Graph API ──────────────────────────────────────────────────────
# developers.facebook.com → seu app → Instagram Graph API
# O token precisa ter escopos: instagram_basic, instagram_content_publish,
# pages_read_engagement, public_profile
INSTAGRAM_ACCOUNT_ID=          # ID numérico da conta Instagram Business
INSTAGRAM_ACCESS_TOKEN=        # Token de longa duração (validade ~60 dias)

# ── Cloudinary (CDN de imagens) ──────────────────────────────────────────────
# console.cloudinary.com → Settings → API Keys
# Crie um upload preset chamado "oab_bot" (unsigned) em Settings → Upload Presets
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Firebase Admin (Firestore — histórico de questões postadas) ───────────────
# firebase.google.com → Console → Configurações do projeto → Contas de serviço
# → Gerar nova chave privada (arquivo JSON)
# FIREBASE_PRIVATE_KEY deve incluir literalmente \n nas quebras de linha
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Claude / Anthropic (geração de legendas — opcional) ──────────────────────
# Necessário apenas se ai.mjs usar a API da Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# ── Configurações do bot ──────────────────────────────────────────────────────
# Número de questões por ciclo antes de reiniciar o pool (padrão: todas as questões)
CYCLE_SIZE=
