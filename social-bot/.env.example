# ── Claude / Anthropic ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Instagram Graph API ──────────────────────────────────
# Obter em: developers.facebook.com → seu app → Instagram Basic Display
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=

# ── Firebase Admin ───────────────────────────────────────
# Baixar em: Firebase Console → Configurações → Contas de serviço
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Configurações do bot ─────────────────────────────────
# Horário de postagem (usado no GitHub Actions cron)
POST_HOUR_UTC=12
# Número de questões por ciclo antes de reiniciar
CYCLE_SIZE=240
